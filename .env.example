# ============================================================================
# Wisp — Casper agentic wallet stack  ·  copy to .env and fill in
# ============================================================================

# --- Agent wallet (buyer) ---------------------------------------------------
# 24-word BIP39 mnemonic. Casper Wallet derivation m/44'/506'/0'/0/<index>.
WISP_MNEMONIC=""
WISP_KEY_ALGO=secp256k1          # secp256k1 | ed25519
WISP_ACCOUNT_INDEX=0

# --- Casper network ---------------------------------------------------------
CASPER_NETWORK=casper:casper-test
CASPER_CHAIN_NAME=casper-test
CASPER_NODE_URL=https://node.testnet.cspr.cloud/rpc

# --- CSPR.cloud -------------------------------------------------------------
CSPR_CLOUD_API_KEY=                # Authorization: <key>  (no Bearer prefix)
CSPR_CLOUD_REST_URL=https://api.testnet.cspr.cloud

# --- x402 facilitator (hosted) ----------------------------------------------
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud
X402_FACILITATOR_API_KEY=          # same CSPR.cloud access key

# --- Payment asset: Wisp Dollar (WISP) --------------------------------------
# A CEP-18 token with EIP-712 transfer_with_authorization, deployed by
# wallet/scripts/deploy-token.ts (initial supply minted to the deployer).
# Deploy your own and paste its package hash here, or reuse this testnet token.
WISP_ASSET_PACKAGE=65bedddde009284db1bd62614afc8bbeb405590ddec1669eca3db38b5e18810f
WISP_ASSET_NAME=Wisp Dollar
WISP_ASSET_VERSION=1
WISP_ASSET_SYMBOL=WISP
WISP_ASSET_DECIMALS=9

# --- Seller -----------------------------------------------------------------
WISP_PAYEE_ADDRESS=                # 00-prefixed account hash that receives WCSPR
WISP_NETWORK_LABEL=Casper Testnet

# --- Wallet budget guardrails (WCSPR) ---------------------------------------
WISP_MAX_PER_CALL=0.10
WISP_MAX_PER_DAY=20.00

# --- CSPR.click (web) -------------------------------------------------------
CSPR_CLICK_APP_ID=
CSPR_CLICK_APP_KEY=

# --- Backend ----------------------------------------------------------------
WISP_ADMIN_SECRET=                 # min 16 chars
PORT=4021
